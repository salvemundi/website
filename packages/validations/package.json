{
    "name": "@salvemundi/validations",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./schema/*": {
            "types": "./dist/schema/*.d.ts",
            "import": "./dist/schema/*.js",
            "default": "./dist/schema/*.js"
        },
        "./directus/*": {
            "types": "./dist/directus/*.d.ts",
            "import": "./dist/directus/*.js",
            "default": "./dist/directus/*.js"
        },
        "./security": {
            "types": "./dist/security.d.ts",
            "import": "./dist/security.js",
            "default": "./dist/security.js"
        }
    },
    "scripts": {
        "build": "tsc",
        "type-check": "tsc --noEmit",
        "lint": "eslint .",
        "typegen": "directus-ts-typegen --output src/directus/schema.ts && node -e \"const fs=require('fs');fs.writeFileSync('src/directus/schema.ts',fs.readFileSync('src/directus/schema.ts','utf8').replace(/: \\\"datetime\\\"/g,': string | \\\"datetime\\\"'))\""
    },
    "dependencies": {
        "drizzle-orm": "0.45.2",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@directus/sdk": "^22.0.0",
        "@types/node": "^26.0.0",
        "directus-ts-typegen": "^0.6.0",
        "eslint": "^9.39.4",
        "typescript": "6.0.3"
    }
}