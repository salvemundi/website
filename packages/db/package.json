{
  "name": "@salvemundi/db",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./dist/schema.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "generate": "drizzle-kit generate",
    "pull": "drizzle-kit pull"
  },
  "dependencies": {
    "postgres": "^3.4.4"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "tsup": "^8.5.1",
    "typescript": "^5.4.5"
  }
}