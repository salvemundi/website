# Environment Configuratie voor Salve Mundi V7
# Kopieer dit bestand naar .env voor lokale ontwikkeling

# --- Database & CMS ---
DB_USER=your_db_user_here
DB_PASSWORD=your_db_password_here
DB_NAME=your_db_name_here
DB_PORT=5432
INTERNAL_DB_HOST=v7-core-db

# Directus Security (Genereer met: openssl rand -base64 32)
DIRECTUS_KEY=your_directus_key_here
DIRECTUS_SECRET=your_directus_secret_here
DIRECTUS_ALLOWED_REDIRECTS=your_allowed_domain_here
DIRECTUS_STATIC_TOKEN=your_static_token_here

# --- Azure Core & Auth ---
AZURE_WEBSITEV7_TENANT_ID=your_tenant_id_here

# WebsiteV7-Auth (Frontend Login)
AZURE_WEBSITEV7_AUTH_CLIENT_ID=your_auth_client_id_here
AZURE_WEBSITEV7_AUTH_CLIENT_SECRET=your_auth_client_secret_here

# WebsiteV7-Sync (Background Processing)
AZURE_WEBSITEV7_SYNC_CLIENT_ID=your_sync_client_id_here
AZURE_WEBSITEV7_SYNC_CLIENT_SECRET=your_sync_client_secret_here

# WebsiteV7-Provisioning (User CRUD)
AZURE_WEBSITEV7_PROVISIONING_CLIENT_ID=your_provisioning_client_id_here
AZURE_WEBSITEV7_PROVISIONING_CLIENT_SECRET=your_provisioning_client_secret_here

# WebsiteV7-Mail (Transactional Emails)
AZURE_WEBSITEV7_MAIL_CLIENT_ID=your_mail_client_id_here
AZURE_WEBSITEV7_MAIL_CLIENT_SECRET=your_mail_client_secret_here

# WebsiteV7-NetBird-VPN (Developer Access)
AZURE_WEBSITEV7_NETBIRD_VPN_CLIENT_ID=your_netbird_client_id_here
AZURE_WEBSITEV7_NETBIRD_VPN_CLIENT_SECRET=your_netbird_client_secret_here

# --- Application Configuration ---
PUBLIC_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=your_better_auth_secret_here

# Shared Secret for Microservice Communication
INTERNAL_SERVICE_TOKEN=your_internal_service_token_here

# Primary Payment Provider
MOLLIE_API_KEY=your_mollie_api_key_here
MOLLIE_WEBHOOK_SECRET=your_mollie_webhook_secret_here

# --- Internal Service URLs (Docker DNS) ---
INTERNAL_DIRECTUS_URL=http://v7-core-directus:8055
INTERNAL_FINANCE_URL=http://finance-service:3001
INTERNAL_SYNC_URL=http://sync-service:3002
INTERNAL_MAIL_URL=http://mail-service:3003
INTERNAL_REDIS_HOST=v7-core-redis
REDIS_PASSWORD=your_redis_password_here
NEXT_APP_INTERNAL_URL=http://localhost:3000
