# Salve Mundi Azure Management Service - Environment Variables

PORT=3004
INTERNAL_SERVICE_TOKEN=salvemundi-dev-token

# Microsoft Graph API (User Provisioning)
AZURE_TENANT_ID=xxxx-xxxx-xxxx-xxxx
AZURE_MANAGEMENT_CLIENT_ID=xxxx-xxxx-xxxx-xxxx
AZURE_MANAGEMENT_CLIENT_SECRET=your-client-secret

# Directus Integration
DIRECTUS_SERVICE_URL=http://localhost:8055
DIRECTUS_STATIC_TOKEN=your-static-admin-token

# Redis (Job Tracking)
REDIS_URL=redis://localhost:6379

TZ=Europe/Amsterdam
