# Salve Mundi Azure Sync Service - Environment Variables

PORT=3002
INTERNAL_SERVICE_TOKEN=salvemundi-dev-token

# Microsoft Graph API (Azure AD Sync)
AZURE_TENANT_ID=xxxx-xxxx-xxxx-xxxx
AZURE_SYNC_CLIENT_ID=xxxx-xxxx-xxxx-xxxx
AZURE_SYNC_CLIENT_SECRET=your-client-secret

# Directus Integration
DIRECTUS_SERVICE_URL=http://localhost:8055
DIRECTUS_STATIC_TOKEN=your-static-admin-token

# Management Service (for new user provisioning)
AZURE_MANAGEMENT_SERVICE_URL=http://localhost:3004

# Redis (Event Stream & Job Tracking)
REDIS_URL=redis://localhost:6379

TZ=Europe/Amsterdam
