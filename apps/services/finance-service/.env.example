# Salve Mundi Finance Service - Environment Variables

PORT=3001
INTERNAL_SERVICE_TOKEN=salvemundi-dev-token

# Mollie API
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Database (PostgreSQL)
DB_URL=postgresql://salvemundi:password@localhost:5432/salvemundi_v7

# Directus Integration
DIRECTUS_SERVICE_URL=http://localhost:8055
DIRECTUS_STATIC_TOKEN=your-static-admin-token

# Redis (Caching)
REDIS_URL=redis://localhost:6379

# External URLs (for redirecting after payment)
PUBLIC_URL=http://localhost:3000
MAIL_SERVICE_URL=http://localhost:3003
NEXT_APP_INTERNAL_URL=http://localhost:3000

TZ=Europe/Amsterdam
