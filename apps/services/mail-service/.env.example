# Salve Mundi Mail Service - Environment Variables

PORT=3003
INTERNAL_SERVICE_TOKEN=salvemundi-dev-token

# Microsoft Graph API (Azure AD)
AZURE_TENANT_ID=xxxx-xxxx-xxxx-xxxx
AZURE_MAIL_CLIENT_ID=xxxx-xxxx-xxxx-xxxx
AZURE_MAIL_CLIENT_SECRET=your-client-secret
AZURE_MAIL_SENDER=info@salvemundi.nl

# Directus Integration
DIRECTUS_SERVICE_URL=http://localhost:8055
DIRECTUS_STATIC_TOKEN=your-static-admin-token

# Database (Logging)
DB_HOST=localhost
DB_USER=salvemundi
DB_PASSWORD=your-db-password
DB_NAME=salvemundi_v7

# Redis (Token Caching)
REDIS_URL=redis://localhost:6379

TZ=Europe/Amsterdam
