{{#> layout headerTitle="PAID & CONFIRMED"}}
    <div class="status-badge">Betaling Ontvangen</div>
    <p>Beste deelnemer,</p>
    
    {{#if (eq registrationType 'trip_signup')}}
        <p>Hoera! Je betaling voor de <strong>Reis ({{eventName}})</strong> is succesvol verwerkt.</p>
        <div class="details">
            <p><strong>Transactie ID:</strong> {{paymentId}}</p>
            <p><strong>Registratie ID:</strong> {{registrationId}}</p>
            <p><strong>Type:</strong> Reis Inschrijving</p>
        </div>
        <p>Je kunt de status van je aanmelding en de details van de reis op elk moment bekijken via je dashboard.</p>
        <p style="text-align: center;">
            <a href="https://salvemundi.nl/reis" class="button">Naar Reis Dashboard</a>
        </p>
    {{else if (eq registrationType 'pub_crawl_signup')}}
        <p>Hoera! Je betaling voor de <strong>{{eventName}}</strong> is succesvol verwerkt.</p>
        <div class="details">
            <p><strong>Transactie ID:</strong> {{paymentId}}</p>
            <p><strong>Registratie ID:</strong> {{registrationId}}</p>
            <p><strong>Type:</strong> {{eventName}} Inschrijving</p>
        </div>
        <p>Je tickets zijn nu beschikbaar in je Salve Mundi profiel. Je kunt ze op elk moment bekijken en downloaden via de onderstaande knop.</p>
        <p style="text-align: center;">
            <a href="https://salvemundi.nl/profiel" class="button">Bekijk Mijn Tickets</a>
        </p>
        <p>Vergeet niet je QR-code(s) mee te nemen naar het startpunt van de kroegentocht! We hebben er zin in.</p>
    {{else}}
        <p>Hoera! Je betaling voor de <strong>{{eventName}}</strong> is succesvol verwerkt.</p>
        <div class="details">
            <p><strong>Transactie ID:</strong> {{paymentId}}</p>
            <p><strong>Registratie ID:</strong> {{registrationId}}</p>
            <p><strong>Type:</strong> {{eventName}} Inschrijving</p>
        </div>
        <p>Bedankt voor je betaling! Je kunt je aanmelding bekijken via je profiel.</p>
        <p style="text-align: center;">
            <a href="https://salvemundi.nl/profiel" class="button">Naar Mijn Profiel</a>
        </p>
    {{/if}}

    <p>Met paarse groet,<br><strong>Bestuur Salve Mundi</strong></p>
{{/layout}}
