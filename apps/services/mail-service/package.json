    "@salvemundi/db": "workspace:*",
    "@salvemundi/validations": "workspace:*",
    "drizzle-orm": "0.45.2",
    "fastify": "5.8.5",
    "fastify-plugin": "^6.0.0",
    "handlebars": "4.7.9",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "typescript": "6.0.3"
  }
}
