# Salve Mundi Frontend - Environment Variables

# Public URL (External facing)
PUBLIC_URL=http://localhost:3000

# Better-Auth Configuration
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=generate-a-long-secret-here

# Directus Configuration
# Use the internal Docker URL if running in compose, otherwise use public URL
INTERNAL_DIRECTUS_URL=http://v7-core-directus:8055
NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8055
DIRECTUS_STATIC_TOKEN=your-static-admin-token

# Microservices URLs (Use localhost if not using Docker containers)
FINANCE_SERVICE_URL=http://localhost:3001
AZURE_SYNC_SERVICE_URL=http://localhost:3002
MAIL_SERVICE_URL=http://localhost:3003
AZURE_MANAGEMENT_SERVICE_URL=http://localhost:3004

# Internal Service Security
INTERNAL_SERVICE_TOKEN=salvemundi-dev-token

# Azure AD Authentication (Entra ID)
AZURE_WEBSITEV7_TENANT_ID=xxxx-xxxx-xxxx-xxxx
AZURE_WEBSITEV7_AUTH_CLIENT_ID=xxxx-xxxx-xxxx-xxxx
AZURE_WEBSITEV7_AUTH_CLIENT_SECRET=your-client-secret

# Database (PostgreSQL)
DB_USER=salvemundi
DB_PASSWORD=your-db-password
DB_NAME=salvemundi_v7
DB_HOST=localhost

# Redis (Caching & Sessions)
REDIS_URL=redis://localhost:6379

# Feature Flags & Management
TZ=Europe/Amsterdam
